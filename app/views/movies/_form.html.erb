<%= form_with(model: movie) do |f| %>
  <% if movie.errors.any? %>
    <div style="color: red">
      <h4><%= pluralize(movie.errors.count, "error") %> prevented save:</h4>
      <ul>
        <% movie.errors.full_messages.each do |msg| %>
          <li><%= msg %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div>
    <%= f.label :title %><br>
    <%= f.text_field :title %>
  </div>

  <div>
    <%= f.label :rating %><br>
    <%= f.select :rating, Movie::RATINGS %>
  </div>

  <div>
    <%= f.label :release_date %><br>
    <%= f.date_field :release_date %>
  </div>

  <div>
    <%= f.label :description %><br>
    <%= f.text_area :description, rows: 5 %>
  </div>

  <div>
    <%= f.submit %>
  </div>
<% end %>
