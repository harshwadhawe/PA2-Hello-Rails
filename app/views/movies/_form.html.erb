<%= form_with(model: movie, class: "needs-validation") do |f| %>
  <% if movie.errors.any? %>
    <div class="alert alert-danger">
      <h5 class="mb-2"><%= pluralize(movie.errors.count, "error") %> prevented this movie from being saved:</h5>
      <ul class="mb-0">
        <% movie.errors.full_messages.each do |msg| %>
          <li><%= msg %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div class="mb-3">
    <%= f.label :title, class: "form-label" %>
    <%= f.text_field :title, class: "form-control", required: true %>
  </div>

  <div class="mb-3">
    <%= f.label :rating, class: "form-label" %>
    <%= f.select :rating, Movie::RATINGS, {}, class: "form-select" %>
  </div>

  <div class="mb-3">
    <%= f.label :release_date, class: "form-label" %>
    <%= f.date_field :release_date, class: "form-control", required: true %>
  </div>

  <div class="mb-3">
    <%= f.label :description, class: "form-label" %>
    <%= f.text_area :description, rows: 5, class: "form-control" %>
  </div>

  <div class="d-flex gap-2">
    <%= f.submit class: "btn btn-primary" %>
    <%= link_to "Cancel", movies_path, class: "btn btn-outline-secondary" %>
  </div>
<% end %>
