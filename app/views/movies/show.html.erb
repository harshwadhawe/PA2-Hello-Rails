<div class="d-flex justify-content-between align-items-center mb-3">
  <h1 class="mb-0"><%= @movie.title %></h1>
  <div class="d-flex gap-2">
    <%= link_to "Edit", edit_movie_path(@movie), class: "btn btn-secondary" %>
    <%= link_to "All Movies", movies_path, class: "btn btn-outline-secondary" %>
  </div>
</div>

<div class="card mb-4">
  <div class="card-body">
    <dl class="row mb-0">
      <dt class="col-sm-3">Rating</dt>
      <dd class="col-sm-9"><%= @movie.rating %></dd>

      <dt class="col-sm-3">Release date</dt>
      <dd class="col-sm-9"><%= @movie.release_date %></dd>

      <dt class="col-sm-3">Description</dt>
      <dd class="col-sm-9"><%= simple_format @movie.description %></dd>
    </dl>
  </div>
</div>

<div class="d-flex gap-2">
  <%= link_to "Delete", @movie,
        data: { turbo_method: :delete, turbo_confirm: "Delete #{@movie.title}?" },
        class: "btn btn-danger" %>
</div>
