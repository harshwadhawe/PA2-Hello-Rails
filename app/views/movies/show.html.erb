<div style="display:flex; justify-content:space-between; align-items:center; gap:1rem; margin-bottom:1rem;">
  <h1><%= @movie.title %></h1>
  <div style="display:flex; gap:.5rem;">
    <%= link_to "Edit", edit_movie_path(@movie), class: "btn" %>
    <%= link_to "All Movies", movies_path, class: "btn muted" %>
  </div>
</div>

<section style="background:#fff; border:1px solid var(--border); border-radius:.5rem; padding:1rem; margin-bottom:1rem;">
  <dl>
    <dt>Rating</dt>
    <dd><%= @movie.rating %></dd>

    <dt>Release date</dt>
    <dd><%= @movie.release_date %></dd>

    <dt>Description</dt>
    <dd><%= simple_format @movie.description %></dd>
  </dl>
</section>

<div style="display:flex; gap:.5rem;">
  <%= link_to "Delete", @movie,
        data: { turbo_method: :delete, turbo_confirm: "Delete #{@movie.title}?" },
        class: "btn danger" %>
</div>
