<div style="display:flex; justify-content:space-between; align-items:center; gap:1rem;">
  <h1>RottenPotatoes</h1>
  <%= link_to "Add Movie", new_movie_path, class: "btn primary" %>
</div>

<% if @movies.any? %>
  <table>
    <thead>
      <tr>
        <% next_dir = ->(col) { (@sort == col && @dir == "asc") ? "desc" : "asc" } %>
        <th class="<%= 'sorted ' + @dir if @sort == 'title' %>">
          <%= link_to "Title", movies_path(sort: "title", dir: next_dir.call("title")), class: "sort-link" %>
        </th>
        <th class="<%= 'sorted ' + @dir if @sort == 'rating' %>">
          <%= link_to "Rating", movies_path(sort: "rating", dir: next_dir.call("rating")), class: "sort-link" %>
        </th>
        <th class="<%= 'sorted ' + @dir if @sort == 'release_date' %>">
          <%= link_to "Release date", movies_path(sort: "release_date", dir: next_dir.call("release_date")), class: "sort-link" %>
        </th>
        <th class="actions">Actions</th>
      </tr>
    </thead>
    <tbody>
      <% @movies.each do |m| %>
        <tr>
          <td><%= link_to m.title, m %></td>
          <td><%= m.rating %></td>
          <td><%= m.release_date %></td>
          <td class="actions">
            <%= link_to "Show", m, class: "btn" %>
            <%= link_to "Edit", edit_movie_path(m), class: "btn" %>
            <%= link_to "Delete", m, data: { turbo_method: :delete, turbo_confirm: "Delete #{m.title}?" }, class: "btn danger" %>
          </td>
        </tr>
      <% end %>
    </tbody>
  </table>
<% else %>
  <div class="flash">No movies yet. Add your first one!</div>
<% end %>
