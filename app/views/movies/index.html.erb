<div class="d-flex justify-content-between align-items-center mb-3">
  <h1 class="mb-0">RottenPotatoes</h1>
  <%= link_to "Add Movie", new_movie_path, class: "btn btn-primary" %>
</div>

<% if @movies.any? %>
  <table class="table table-striped table-bordered">
    <thead class="table-dark">
      <tr>
        <th>Title</th>
        <th>Rating</th>
        <th>Release date</th>
        <th style="width: 220px;"></th>
      </tr>
    </thead>
    <tbody>
      <% @movies.each do |m| %>
        <tr>
          <td><%= link_to m.title, m %></td>
          <td><%= m.rating %></td>
          <td><%= m.release_date %></td>
          <td class="text-nowrap">
            <%= link_to "Show", m, class: "btn btn-sm btn-outline-primary" %>
            <%= link_to "Edit", edit_movie_path(m), class: "btn btn-sm btn-secondary" %>
            <%= link_to "Delete", m,
                  data: { turbo_method: :delete, turbo_confirm: "Delete #{m.title}?" },
                  class: "btn btn-sm btn-danger" %>
          </td>
        </tr>
      <% end %>
    </tbody>
  </table>
<% else %>
  <div class="alert alert-info">No movies yet. Add your first one!</div>
<% end %>
